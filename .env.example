# ============================================================
# BARBER PRO - Variáveis de Ambiente
# Copie para .env.local e preencha os valores
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# OneSignal
NEXT_PUBLIC_ONESIGNAL_APP_ID=seu_app_id_aqui
ONESIGNAL_REST_API_KEY=sua_rest_api_key_aqui

# App
NEXT_PUBLIC_APP_URL=https://seudominio.com.br
NEXT_PUBLIC_APP_NAME=Barber Pro

# (Opcional) Pagamento PIX via Mercado Pago ou EFI
MERCADOPAGO_ACCESS_TOKEN=seu_token_aqui
